<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Stats bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="BF" android:textSize="11sp" android:textColor="#888888"/>
            <TextView android:id="@+id/tvBF"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textSize="28sp" android:textStyle="bold" android:textColor="#333333"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Balls" android:textSize="11sp" android:textColor="#1a5fa8"/>
            <TextView android:id="@+id/tvBalls"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textSize="28sp" android:textStyle="bold" android:textColor="#1a5fa8"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Strikes" android:textSize="11sp" android:textColor="#c0392b"/>
            <TextView android:id="@+id/tvStrikes"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textSize="28sp" android:textStyle="bold" android:textColor="#c0392b"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Pitch" android:textSize="11sp" android:textColor="#888888"/>
            <TextView android:id="@+id/tvPitchCount"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="#1" android:textSize="18sp" android:textStyle="bold" android:textColor="#333333"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Pitch log -->
    <ScrollView
        android:id="@+id/scrollPitchLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/pitchLogLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <!-- Big buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:elevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnBall"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:text="BALL"
                android:textSize="22sp"
                android:textStyle="bold"
                android:backgroundTint="#1a5fa8"
                android:textColor="@android:color/white"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnStrike"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:text="STRIKE"
                android:textSize="22sp"
                android:textStyle="bold"
                android:backgroundTint="#c0392b"
                android:textColor="@android:color/white" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnBatterFaced"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="+ BATTER"
                android:textSize="16sp"
                android:backgroundTint="#3B6D11"
                android:textColor="@android:color/white"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnUndo"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="↩ RÜCKGÄNGIG"
                android:textSize="14sp"
                android:backgroundTint="#888888"
                android:textColor="@android:color/white" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
