<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- Batting order number -->
        <TextView
            android:id="@+id/tvBattingOrder"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/badge_position" />

        <!-- Jersey number -->
        <TextView
            android:id="@+id/tvJerseyNumber"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="–"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:paddingStart="16dp"
            android:paddingEnd="8dp" />

        <!-- Sub button -->
        <Button
            android:id="@+id/btnSub"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Wechsel"
            android:textSize="12sp"
            android:backgroundTint="#d35400"
            android:textColor="@android:color/white"
            android:layout_marginEnd="6dp" />

        <!-- Edit button -->
        <Button
            android:id="@+id/btnEditSlot"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="✎"
            android:textSize="16sp"
            android:backgroundTint="#1a5fa8"
            android:textColor="@android:color/white" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
