<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Name"
        android:textSize="12sp"
        android:textColor="#888888" />

    <EditText
        android:id="@+id/etPlayerName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Vor- und Nachname"
        android:inputType="textPersonName|textCapWords"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Trikotnummer"
        android:textSize="12sp"
        android:textColor="#888888" />

    <EditText
        android:id="@+id/etPlayerNumber"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="z.B. 7"
        android:inputType="number"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hauptposition"
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginBottom="4dp" />

    <Spinner
        android:id="@+id/spinnerPosition"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Zweite Position"
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginBottom="4dp" />

    <Spinner
        android:id="@+id/spinnerSecondaryPosition"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp" />

    <CheckBox
        android:id="@+id/cbIsPitcher"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pitcher"
        android:textSize="15sp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Geburtsjahr"
        android:textSize="12sp"
        android:textColor="#888888" />

    <EditText
        android:id="@+id/etBirthYear"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="z.B. 2009"
        android:inputType="number"
        android:maxLength="4" />

</LinearLayout>
