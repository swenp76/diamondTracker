<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp">

    <Button
        android:id="@+id/btnOffense"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:text="Offense"
        android:textSize="22sp"
        android:textColor="@android:color/white"
        android:backgroundTint="#1a5fa8"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnDefense"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:text="Defense"
        android:textSize="22sp"
        android:textColor="@android:color/white"
        android:backgroundTint="#c0392b"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnLineup"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:text="Lineup"
        android:textSize="22sp"
        android:textColor="@android:color/white"
        android:backgroundTint="#2c7a2c"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnOppoLineup"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:text="Oppo-Lineup"
        android:textSize="22sp"
        android:textColor="@android:color/white"
        android:backgroundTint="#7d3c98"
        android:layout_marginBottom="0dp" />

</LinearLayout>
