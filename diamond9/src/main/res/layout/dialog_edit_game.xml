<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_date"
        android:textSize="12sp"
        android:textColor="#888888" />

    <EditText
        android:id="@+id/etEditDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="none"
        android:hint="@string/hint_date_format"
        android:focusable="false"
        android:clickable="true"
        android:drawableEnd="@android:drawable/ic_menu_today"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_opponent"
        android:textSize="12sp"
        android:textColor="#888888" />

    <Spinner
        android:id="@+id/spinnerEditOpponent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvOrEnterEdit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_or_enter_new"
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginBottom="4dp"
        android:visibility="gone" />

    <AutoCompleteTextView
        android:id="@+id/etEditOpponent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_opponent"
        android:inputType="textCapWords"
        android:completionThreshold="1" />

</LinearLayout>
