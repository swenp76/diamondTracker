<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Jersey Number -->
        <TextView
            android:id="@+id/tvPlayerNumber"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1a5fa8"
            android:background="@drawable/badge_ball"
            android:layout_marginEnd="12dp" />

        <!-- Name -->
        <TextView
            android:id="@+id/tvPlayerName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333" />

        <!-- Pitcher Badge -->
        <TextView
            android:id="@+id/tvPitcherBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="P"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:background="#1a5fa8"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:layout_marginEnd="6dp"
            android:visibility="gone" />

        <!-- Primary Position Badge -->
        <TextView
            android:id="@+id/tvPlayerPosition"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#c0392b"
            android:background="@drawable/badge_position"
            android:layout_marginEnd="4dp" />

        <!-- Secondary Position Badge -->
        <TextView
            android:id="@+id/tvPlayerSecondaryPosition"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#888888"
            android:background="@drawable/badge_position"
            android:layout_marginEnd="8dp"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/btnDeletePlayer"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#c0392b" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
