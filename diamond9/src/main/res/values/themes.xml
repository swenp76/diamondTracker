<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Diamond9" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <item name="colorPrimary">#1a5fa8</item>
        <item name="colorPrimaryVariant">#0c447c</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">#c0392b</item>
        <item name="colorSecondaryVariant">#a32d2d</item>
        <item name="colorOnSecondary">@android:color/white</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#f5f5f5</item>
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.Diamond9</item>
    </style>
</resources>
